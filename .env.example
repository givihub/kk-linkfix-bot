# Скопируйте в .env и заполните. Файл .env НИКОГДА не коммитится (см. .gitignore).
BOT_TOKEN=1234567890:AAAA...
# Прокси для Telegram API (на FreeTier — локальный Xray). Оставьте пустым, если не нужен.
PROXY_URL=http://127.0.0.1:7890
# Цепочки доменов-фиксеров (через запятую, порядок = приоритет).
# Бот пробует по очереди: redirect на mp4 или og:video со страницы.
INSTAGRAM_FIX_DOMAINS=kkinstagram.com,vxinstagram.com
TIKTOK_FIX_DOMAINS=kktiktok.com,tnktok.com,a.tnktok.com
TWITTER_FIX_DOMAINS=d.fixupx.com,d.fxtwitter.com,d.vxtwitter.com
# Откуда подтягивать автора и текст поста (og-теги). Пусто = не подтягивать.
TIKTOK_CAPTION_DOMAIN=tnktok.com
TWITTER_CAPTION_DOMAIN=fixupx.com
INSTAGRAM_CAPTION_DOMAIN=
